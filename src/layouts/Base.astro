---
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "WCW – Weischnors Consulting Woltersdorf",
  description = "Ihr persönlicher Partner für Praxis- und Sprechstundenbedarf in Berlin, Brandenburg und deutschlandweit. Seit über 20 Jahren – persönlich, schnell, fair.",
} = Astro.props;
---

<!doctype html>
<html lang="de">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="icon" type="image/png" href="/assets/wcw-symbol-dark.png" />
    <link
      rel="preload"
      href="/fonts/space-grotesk.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />
    <link
      rel="preload"
      href="/fonts/hanken-grotesk.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />
  </head>
  <body>
    <slot />
    <!-- 100% privacy-first analytics -->
    <script
      is:inline
      data-collect-dnt="true"
      async
      src="https://scripts.simpleanalyticscdn.com/latest.js"></script>
    <noscript
      ><img
        src="https://queue.simpleanalyticscdn.com/noscript.gif?collect-dnt=true"
        alt=""
        referrerpolicy="no-referrer-when-downgrade"
      /></noscript>
  </body>
</html>
