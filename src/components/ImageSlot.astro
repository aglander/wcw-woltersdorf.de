---
interface Props {
  placeholder: string;
  class?: string;
  src?: string;
  alt?: string;
  /** true für das LCP-Bild (Hero): sofort + priorisiert laden */
  eager?: boolean;
}

const { placeholder, class: className, src, alt, eager = false } = Astro.props;
---

{
  src ? (
    <img
      class:list={["img-filled", className]}
      src={src}
      alt={alt ?? placeholder}
      loading={eager ? "eager" : "lazy"}
      fetchpriority={eager ? "high" : undefined}
      decoding="async"
    />
  ) : (
    <div class:list={["img-slot", className]} role="img" aria-label={placeholder}>
      <span>{placeholder}</span>
    </div>
  )
}

<style>
  .img-filled {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
</style>
