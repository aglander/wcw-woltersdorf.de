---
// Auf der Startseite reichen reine Sprung-Anker; auf anderen Seiten
// (Impressum, Datenschutz) müssen die Links erst zur Startseite führen.
const isHome = Astro.url.pathname === "/";
const anchor = (id: string) => (isHome ? `#${id}` : `/#${id}`);

const links = [
  { id: "leistungen", label: "Sortiment" },
  { id: "vorteil", label: "Warum WCW" },
  { id: "ablauf", label: "Ablauf" },
  { id: "christian", label: "Über mich" },
];
---

<header class="site">
  <div class="wrap nav">
    <a class="brand" href="/" aria-label="WCW – zur Startseite">
      <img src="/assets/wcw-symbol-dark.png" alt="WCW Logo" />
      <span class="bt"><b>WCW</b><span>Weischnors Consulting</span></span>
    </a>
    <nav class="nav-links">
      {links.map((l) => <a href={anchor(l.id)}>{l.label}</a>)}
    </nav>
    <div class="nav-cta">
      <a
        class="nav-wa"
        href="https://wa.me/4917641137908"
        target="_blank"
        rel="noopener"
        aria-label="WCW per WhatsApp kontaktieren (0176 41137908)"
      >
        <svg class="wa-icon" viewBox="0 0 24 24" width="18" height="18" aria-hidden="true">
          <path
            fill="currentColor"
            d="M12.04 2C6.58 2 2.13 6.45 2.13 11.91c0 1.75.46 3.46 1.32 4.97L2 22l5.25-1.38a9.9 9.9 0 0 0 4.79 1.22h.01c5.46 0 9.91-4.45 9.91-9.91 0-2.65-1.03-5.14-2.9-7.01A9.86 9.86 0 0 0 12.04 2Zm0 18.13h-.01a8.2 8.2 0 0 1-4.18-1.15l-.3-.18-3.12.82.83-3.04-.2-.31a8.18 8.18 0 0 1-1.26-4.39c0-4.54 3.7-8.23 8.24-8.23 2.2 0 4.27.86 5.83 2.42a8.18 8.18 0 0 1 2.41 5.82c0 4.54-3.7 8.24-8.24 8.24Zm4.52-6.16c-.25-.12-1.47-.72-1.69-.81-.23-.08-.39-.12-.56.13-.16.25-.64.81-.78.97-.14.17-.29.19-.54.06-.25-.12-1.05-.39-1.99-1.23-.74-.66-1.23-1.47-1.38-1.72-.14-.25-.01-.38.11-.51.11-.11.25-.29.37-.43.12-.14.16-.25.25-.41.08-.17.04-.31-.02-.43-.06-.12-.56-1.34-.76-1.84-.2-.48-.41-.42-.56-.43h-.48c-.17 0-.43.06-.66.31-.22.25-.86.85-.86 2.07 0 1.22.89 2.4 1.01 2.56.12.17 1.75 2.67 4.24 3.74.59.26 1.05.41 1.41.52.59.19 1.13.16 1.56.1.48-.07 1.47-.6 1.68-1.18.21-.58.21-1.07.14-1.18-.06-.1-.22-.16-.47-.28Z"
          ></path>
        </svg>
        <span class="np-num">0176 41137908</span>
      </a>
      <a class="btn btn-primary" href={anchor("angebot")}>Angebot anfordern</a>
    </div>
  </div>
</header>

<style>
  header.site {
    position: sticky;
    top: 0;
    z-index: 50;
    background: rgba(255, 255, 255, 0.9);
    backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--line-soft);
  }
  .nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 76px;
  }
  .brand {
    display: flex;
    align-items: center;
    gap: 12px;
  }
  .brand img {
    width: 36px;
    height: 36px;
  }
  .brand .bt {
    display: flex;
    flex-direction: column;
    line-height: 1.05;
  }
  .brand .bt b {
    font-family: var(--disp);
    font-weight: 700;
    font-size: 19px;
    letter-spacing: 0;
  }
  .brand .bt span {
    font-size: 10.5px;
    letter-spacing: 0.13em;
    text-transform: uppercase;
    color: var(--ink-faint);
    font-weight: 600;
  }
  .nav-links {
    display: flex;
    align-items: center;
    gap: 28px;
  }
  .nav-links a {
    font-family: var(--disp);
    font-size: 15px;
    font-weight: 500;
    color: var(--ink-soft);
  }
  .nav-links a:hover {
    color: var(--green-deep);
  }
  .nav-cta {
    display: flex;
    align-items: center;
    gap: 16px;
  }
  .nav-wa {
    font-family: var(--disp);
    font-weight: 600;
    font-size: 15px;
    display: inline-flex;
    align-items: center;
    gap: 7px;
    color: var(--ink);
  }
  .nav-wa .wa-icon {
    color: #25d366;
    flex: none;
  }
  .nav-wa:hover {
    color: var(--green-deep);
  }
  @media (max-width: 920px) {
    .nav-links {
      display: none;
    }
    .nav-wa {
      display: none;
    }
  }
</style>
