<footer class="site">
  <div class="wrap">
    <div class="foot-grid">
      <div>
        <div class="foot-brand">
          <img src="/assets/wcw-symbol-light.png" alt="WCW" /><b>WCW</b>
        </div>
        <p class="foot-about">
          Weischnors Consulting Woltersdorf — Ihr persönlicher Partner für
          Praxis- und Sprechstundenbedarf in Berlin, Brandenburg und
          deutschlandweit.
        </p>
      </div>
      <div>
        <div class="fh">Kontakt</div>
        <a class="fl" href="tel:033626530014">03362 6530014</a>
        <a class="fl" href="tel:01627327400">0162 7327400</a>
        <a class="fl" href="mailto:vertrieb@wcw-woltersdorf.de"
          >vertrieb@wcw-woltersdorf.de</a
        >
      </div>
      <div>
        <div class="fh">Anschrift</div>
        <span class="fl">Zu den Eichen 6</span>
        <span class="fl">15569 Woltersdorf</span>
        <span class="fl liefer">Liefergebiet: deutschlandweit</span>
      </div>
    </div>
    <div class="foot-bottom">
      <span>© 2026 WCW – Weischnors Consulting Woltersdorf</span>
      <span class="foot-legal">
        <a href="/impressum">Impressum</a> ·
        <a href="/datenschutz">Datenschutz</a>
      </span>
    </div>
  </div>
</footer>

<style>
  footer.site {
    background: var(--dark);
    color: #afc0b4;
    padding: 60px 0 38px;
  }
  .foot-grid {
    display: grid;
    grid-template-columns: 1.4fr 1fr 1fr;
    gap: 40px;
    padding-bottom: 40px;
    border-bottom: 1px solid rgba(255, 255, 255, 0.1);
  }
  .foot-brand {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 16px;
  }
  .foot-brand img {
    width: 40px;
    height: 40px;
  }
  .foot-brand b {
    color: #fff;
    font-family: var(--disp);
    font-weight: 700;
    font-size: 20px;
  }
  .foot-about {
    max-width: 24em;
    font-size: 15.5px;
  }
  .fh {
    color: #fff;
    font-family: var(--disp);
    font-weight: 600;
    font-size: 13px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    margin-bottom: 16px;
  }
  footer a:hover {
    color: #fff;
  }
  .fl {
    display: block;
    margin-bottom: 9px;
    font-size: 15.5px;
  }
  .liefer {
    margin-top: 14px;
    color: #fff;
  }
  .foot-bottom {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding-top: 22px;
    font-size: 13.5px;
    color: var(--ink-faint);
    flex-wrap: wrap;
    gap: 12px;
  }
  .foot-legal a {
    color: #afc0b4;
  }
  .foot-legal a:hover {
    color: #fff;
  }

  @media (max-width: 900px) {
    .foot-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
