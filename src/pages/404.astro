---
import Base from "../layouts/Base.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
---

<Base
  title="Seite nicht gefunden – WCW Weischnors Consulting Woltersdorf"
  description="Diese Seite existiert nicht. Zurück zur Startseite von WCW – Weischnors Consulting Woltersdorf."
>
  <Header />
  <main id="top" class="nf">
    <div class="wrap nf-wrap">
      <p class="eyebrow">Fehler 404</p>
      <h1>Diese Seite gibt es nicht.</h1>
      <p class="lead">
        Vielleicht hat sich ein Tippfehler eingeschlichen oder die Seite wurde
        verschoben. Kein Problem — ich helfe Ihnen gern persönlich weiter.
      </p>
      <div class="nf-cta">
        <a class="btn btn-primary" href="/">Zur Startseite</a>
        <a class="btn btn-ghost" href="/#angebot">Angebot anfordern</a>
      </div>
      <p class="nf-contact">
        Lieber direkt? <a href="tel:01627327400">0162 7327400</a> ·
        <a href="mailto:vertrieb@wcw-woltersdorf.de">vertrieb@wcw-woltersdorf.de</a>
      </p>
    </div>
  </main>
  <Footer />
</Base>

<style>
  .nf {
    padding: 96px 0 120px;
  }
  .nf-wrap {
    max-width: 640px;
  }
  .nf h1 {
    font-size: 48px;
    margin: 14px 0 0;
    letter-spacing: -0.025em;
  }
  .nf .lead {
    margin-top: 18px;
  }
  .nf-cta {
    display: flex;
    flex-wrap: wrap;
    gap: 13px;
    margin-top: 32px;
  }
  .nf-contact {
    margin-top: 28px;
    color: var(--ink-soft);
    font-size: 16px;
  }
  .nf-contact a {
    color: var(--green-deep);
    text-decoration: underline;
    text-underline-offset: 2px;
  }
  .nf-contact a:hover {
    color: var(--green);
  }

  @media (max-width: 560px) {
    .nf {
      padding: 56px 0 80px;
    }
    .nf h1 {
      font-size: 34px;
    }
  }
</style>
